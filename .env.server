# Server/browser public endpoints for production deployment.
# Keep secrets in .env or your server secret manager; this file is only for host/API URLs.
APP_ENV=production
PUBLIC_HOST=cmtdigi.com

API_HOST_PORT=4005
WEB_HOST_PORT=3005
STOREFRONT_HOST_PORT=3006

NEXT_PUBLIC_API_BASE_URL=https://cmtdigi.com:4005
NEXT_PUBLIC_ADMIN_BASE_URL=https://cmtdigi.com:3005
NEXT_PUBLIC_STOREFRONT_BASE_URL=https://cmtdigi.com:3006
NEXT_PUBLIC_STORE_SLUG=rangavali

WEB_APP_URL=https://cmtdigi.com
ALLOWED_ORIGINS=https://cmtdigi.com,https://www.cmtdigi.com
AMAZON_LWA_REDIRECT_URL=https://cmtdigi.com/v1/amazon/oauth/callback

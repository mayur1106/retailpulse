# Local browser/public endpoints
APP_ENV=local
PUBLIC_HOST=localhost

API_HOST_PORT=4005
WEB_HOST_PORT=3005
STOREFRONT_HOST_PORT=3006

NEXT_PUBLIC_API_BASE_URL=http://localhost:4005
# Docker-only internal API URL used by the storefront container/Next rewrites.
# Browser-facing URLs stay localhost above; containers must call the Compose service name.
RETAILPULSE_API_INTERNAL_URL=http://api:4005
NEXT_PUBLIC_ADMIN_BASE_URL=http://localhost:3005
NEXT_PUBLIC_STOREFRONT_BASE_URL=http://localhost:3006
NEXT_PUBLIC_STORE_SLUG=rangavali

WEB_APP_URL=http://localhost:3005
ALLOWED_ORIGINS=http://localhost:3005,http://localhost:3006,http://localhost:3003,http://localhost:3000,http://127.0.0.1:3005,http://127.0.0.1:3006,http://127.0.0.1:3003,http://127.0.0.1:3000
AMAZON_LWA_REDIRECT_URL=http://localhost:4005/v1/amazon/oauth/callback
